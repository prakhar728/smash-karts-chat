{
  "manifest_version": 3,
  "name": "SmashKarts Room Chat",
  "version": "0.1.0",
  "description": "Room-based chat overlay for SmashKarts modes.",
  "permissions": ["identity", "storage"],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "http://localhost:8080/*",
    "https://smashkarts.io/*"
  ],
  "oauth2": {
    "client_id": "REPLACE_WITH_CHROME_OAUTH_CLIENT_ID",
    "scopes": ["openid", "profile", "email"]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://smashkarts.io/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://smashkarts.io/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}
